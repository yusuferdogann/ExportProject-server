// ============================================================================
//  ENTERPRISE MAIL — event + cache + incremental sync (no polling)
//  Gmail/Outlook webhook → queue event → worker → S3 + PG (+ OpenSearch later)
// ============================================================================

enum MailAccountProvider {
  ses_domain
  gmail
  microsoft
  yahoo
  imap_custom
}

enum MailAccountStatus {
  pending
  active
  error
  disconnected
}

enum MailFolder {
  inbox
  sent
  drafts
  trash
  archive
  spam
  other
}

enum MailSyncEventType {
  gmail_push
  microsoft_notification
  ses_inbound
  ses_bounce
  manual_resync
  send_request
  send_completed
  incremental_sync
}

enum MailSyncEventStatus {
  pending
  processing
  done
  failed
  dead
}

/// Bagli posta hesabi: user@firma.com (SES) veya OAuth (Gmail/Outlook/…)
model MailAccount {
  id            String              @id @default(uuid()) @db.Uuid
  emailAddress  String
  displayName   String?
  provider      MailAccountProvider
  status        MailAccountStatus   @default(pending)
  isDefault     Boolean             @default(false)
  /// OAuth tokenlari uygulama katmaninda sifrelenmis JSON olarak saklanir
  credentials   Json?
  /// Incremental sync cursor (provider-specific)
  gmailHistoryId       String?
  microsoftDeltaLink   String? @db.Text
  microsoftSubscriptionId String?
  sesIdentityArn       String?
  lastSyncAt           DateTime?
  lastSyncError        String? @db.Text
  webhookExpiresAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  companyId String  @db.Uuid
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  threads       MailThread[]
  messages      MailMessage[]
  syncEvents    MailSyncEvent[]
  subscriptions MailWebhookSubscription[]

  @@unique([userId, emailAddress])
  @@index([companyId, status])
  @@map("mail_accounts")
}

model MailThread {
  id               String    @id @default(uuid()) @db.Uuid
  providerThreadId String?
  subject          String?
  snippet          String?   @db.Text
  participantEmails String[] @default([])
  lastMessageAt    DateTime?
  messageCount     Int       @default(0)
  labels           String[]  @default([])
  isRead           Boolean   @default(false)
  isStarred        Boolean   @default(false)
  isArchived       Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  companyId String  @db.Uuid
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  mailAccountId String      @db.Uuid
  mailAccount   MailAccount @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)

  messages MailMessage[]

  @@unique([mailAccountId, providerThreadId])
  @@index([mailAccountId, lastMessageAt(sort: Desc)])
  @@map("mail_threads")
}

model MailMessage {
  id                String     @id @default(uuid()) @db.Uuid
  providerMessageId String
  folder            MailFolder @default(inbox)
  fromEmail         String
  fromName          String?
  toEmails          String[]   @default([])
  ccEmails          String[]   @default([])
  bccEmails         String[]   @default([])
  subject           String?
  snippet           String?    @db.Text
  bodyText          String?    @db.Text
  bodyHtml          String?    @db.Text
  /// Tam MIME / buyuk HTML S3'te; burada sadece key
  s3RawKey          String?
  s3BodyHtmlKey     String?
  hasAttachments    Boolean    @default(false)
  isRead            Boolean    @default(false)
  isDraft           Boolean    @default(false)
  isOutbound        Boolean    @default(false)
  sentAt            DateTime?
  receivedAt        DateTime?
  headers           Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  companyId String  @db.Uuid
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  mailAccountId String      @db.Uuid
  mailAccount   MailAccount @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)

  threadId String?     @db.Uuid
  thread   MailThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)

  attachments MailAttachment[]

  @@unique([mailAccountId, providerMessageId])
  @@index([mailAccountId, folder, receivedAt(sort: Desc)])
  @@index([threadId])
  @@map("mail_messages")
}

model MailAttachment {
  id          String  @id @default(uuid()) @db.Uuid
  filename    String
  contentType String?
  sizeBytes   Int?
  s3Key       String
  createdAt   DateTime @default(now())

  messageId String      @db.Uuid
  message   MailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("mail_attachments")
}

/// Webhook/push → DB queue (ileride SQS ile ayni payload)
model MailSyncEvent {
  id             String              @id @default(uuid()) @db.Uuid
  type           MailSyncEventType
  status         MailSyncEventStatus @default(pending)
  idempotencyKey String              @unique
  payload        Json                @default("{}")
  attempts       Int                 @default(0)
  lastError      String?             @db.Text
  scheduledAt    DateTime            @default(now())
  processedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  companyId String  @db.Uuid
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  mailAccountId String?      @db.Uuid
  mailAccount   MailAccount? @relation(fields: [mailAccountId], references: [id], onDelete: SetNull)

  @@index([status, scheduledAt])
  @@index([mailAccountId, type])
  @@map("mail_sync_events")
}

model MailWebhookSubscription {
  id              String   @id @default(uuid()) @db.Uuid
  provider        MailAccountProvider
  externalSubId   String
  resourceId      String?
  expiresAt       DateTime?
  clientState     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  mailAccountId String      @db.Uuid
  mailAccount   MailAccount @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)

  @@unique([mailAccountId, provider, externalSubId])
  @@map("mail_webhook_subscriptions")
}

/// OAuth CSRF state (sunucu restart sonrasi da gecerli)
model MailOAuthState {
  state      String              @id
  userId     String              @db.Uuid
  companyId  String              @db.Uuid
  provider   MailAccountProvider
  returnPath String              @default("/settings/email-accounts")
  expiresAt  DateTime
  createdAt  DateTime            @default(now())

  @@index([expiresAt])
  @@map("mail_oauth_states")
}
