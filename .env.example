# MongoDB
MONGO_URI=your_mongodb_uri

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret
JWT_SECRET_KEY=your_jwt_secret_key
JWT_EXPIRE=60m
JWT_COOKIE=60

# PostgreSQL (Prisma)
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=your_pg_user
PG_PASSWORD=your_pg_password
PG_DATABASE=ihracattakip
PG_SSL=false
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/ihracattakip?schema=public

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# --- Enterprise mail OAuth ---
# Tek satir degistirerek local / canli ayir:
#   Local PC:     MAIL_OAUTH_ENV=local
#   VPS canli:    MAIL_OAUTH_ENV=production
#
# Google Console → Authorized redirect URIs (IKISI DE kayitli olmali):
#   http://localhost:5000/api/pg/enterprise-mail/oauth/gmail/callback
#   https://app.ihracattakip.com/api/pg/enterprise-mail/oauth/gmail/callback

MAIL_OAUTH_ENV=local
GOOGLE_MAIL_CLIENT_ID=
GOOGLE_MAIL_CLIENT_SECRET=
MAIL_CREDENTIALS_SECRET=change-me-long-random-string

# Opsiyonel override (genelde bos birakin; profil otomatik URL verir):
# GOOGLE_MAIL_REDIRECT_URI=
# APP_PUBLIC_URL=

# GOOGLE_MAIL_PUBSUB_TOPIC=projects/YOUR_PROJECT/topics/gmail-push

# AWS SES / S3
# AWS_REGION=eu-central-1
# SES_FROM_EMAIL=info@yourdomain.com
# ENTERPRISE_MAIL_S3_BUCKET=
